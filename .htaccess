# ============================================================
# Keewatin Self Storage — Apache .htaccess
# Core Web Vitals, SEO, Security
# ============================================================

# --- Force HTTPS ---
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Force www ---
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Remove .html extension (clean URLs) ---
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# --- Redirect /index.html → / ---
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+index\.html [NC]
RewriteRule ^index\.html$ / [R=301,L]

# ============================================================
# Gzip Compression
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml text/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2 font/woff
</IfModule>

# ============================================================
# Browser Cache Headers (Core Web Vitals — LCP/FID)
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short TTL so updates are seen quickly
  ExpiresByType text/html                   "access plus 1 hour"

  # CSS / JS — long TTL (filename-hash busting recommended)
  ExpiresByType text/css                    "access plus 1 year"
  ExpiresByType application/javascript      "access plus 1 year"

  # Images
  ExpiresByType image/png                   "access plus 1 year"
  ExpiresByType image/jpeg                  "access plus 1 year"
  ExpiresByType image/webp                  "access plus 1 year"
  ExpiresByType image/svg+xml               "access plus 1 year"
  ExpiresByType image/x-icon               "access plus 1 year"

  # Fonts
  ExpiresByType font/woff2                  "access plus 1 year"
  ExpiresByType font/woff                   "access plus 1 year"
  ExpiresByType application/font-woff2      "access plus 1 year"

  # JSON (availability data) — short TTL
  ExpiresByType application/json            "access plus 10 minutes"

  # XML (sitemap)
  ExpiresByType application/xml             "access plus 1 day"
  ExpiresByType text/xml                    "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  # Cache-Control fallback
  <FilesMatch "\.(css|js|woff2|woff|png|jpg|jpeg|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
  <FilesMatch "availability\.json$">
    Header set Cache-Control "public, max-age=600, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================================
# Security Headers
# ============================================================
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ============================================================
# Error Pages
# ============================================================
ErrorDocument 404 /index.html

# ============================================================
# Prevent directory listing
# ============================================================
Options -Indexes
